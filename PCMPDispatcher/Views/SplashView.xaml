<UserControl x:Class="PCMPDispatcher.SplashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid x:Name="Root" Background="White">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid HorizontalAlignment="Center">
                    <TextBlock x:Name="SplashWelcome"
                               Text="Welcome"
                               FontSize="64" FontWeight="Black"
                               Foreground="#000000"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               TextOptions.TextFormattingMode="Ideal"
                               RenderOptions.ClearTypeHint="Enabled">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="WelcomeScale" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="SplashTagline"
                               Text="for You - for Us. For everyone."
                               FontSize="26" FontWeight="Normal"
                               Foreground="#000000"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               RenderTransformOrigin="0.5,0.5"
                               TextOptions.TextFormattingMode="Ideal"
                               RenderOptions.ClearTypeHint="Enabled">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="TaglineScale" ScaleY="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
                <Border x:Name="SplashProgressTrack" Height="3" Width="300" Margin="0,40,0,0"
                        Background="#EEEEEE" CornerRadius="2">
                    <Border x:Name="SplashProgress" HorizontalAlignment="Left"
                            Background="#3458e1" Height="3" Width="0" CornerRadius="2"/>
                </Border>
            </StackPanel>
            <TextBlock Text="PC|MP Dispatch System" FontSize="11" Foreground="#CCCCCC"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,16"/>
        </Grid>
</UserControl>
