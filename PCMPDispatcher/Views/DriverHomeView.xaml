<UserControl x:Class="PCMPDispatcher.DriverHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid x:Name="Root" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- ── Top bar (universal) ── -->
            <Border Grid.Row="0" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Background="White">
                <Grid Margin="28,0,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="/Assets/logo.png" Width="160" Height="42"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                            <TextBlock x:Name="DrvClockText" Text="00:00:00"
                                       FontSize="22" FontWeight="SemiBold" Foreground="#111111" FontFamily="Bahnschrift" HorizontalAlignment="Center"
                                       TextOptions.TextFormattingMode="Display"
                                       SnapsToDevicePixels="True"/>
                            <TextBlock x:Name="DrvDateText" Text="01.06.2026"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#555555" FontFamily="Bahnschrift SemiLight" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Border Width="1" Height="36" Background="#EEEEEE" Margin="0,0,24,0"/>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" Fill="#28A745" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#28A745" Opacity="0.8" BlurRadius="6" ShadowDepth="0"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="RO.sv-1" FontSize="14" FontWeight="Bold"
                                           Foreground="#000000" Margin="7,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Active" FontSize="11" Foreground="#28A745" Margin="16,0,0,0"/>
                        </StackPanel>
                        <Border Width="1" Height="36" Background="#EEEEEE" Margin="0,0,24,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Active players" FontSize="11" Foreground="#888888"/>
                            <TextBlock Text="13" FontSize="20" FontWeight="Black" Foreground="#3458e1"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,150,0">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock Text="Welcome," FontSize="12" Foreground="#888888" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="DrvUserName" Text="Polikarp"
                                       FontSize="16" FontWeight="Bold" Foreground="#000000" HorizontalAlignment="Right"/>
                        </StackPanel>
                        <Border Width="44" Height="44" CornerRadius="6" Background="#E8EEFF" VerticalAlignment="Center">
                            <TextBlock Text="P" FontSize="20" FontWeight="Bold" Foreground="#3458e1"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main 2-column (50/50) — empty white for now ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical separator -->
                <Border Grid.Column="0" Width="1" Background="#F0F0F0"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"/>

                <!-- ═══ LEFT PANEL (route selection for the driver) ═══ -->
                <Grid Grid.Column="0" Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Which route today, Driver?"
                                   FontSize="26" FontWeight="Black" Foreground="#000000"
                                   TextOptions.TextFormattingMode="Ideal"/>
                        <TextBlock Text="Pick a route to start your shift"
                                   FontSize="15" Foreground="#666666" Margin="0,5,0,0"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- "Available Routes" + divider -->
                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="Available Routes" FontSize="14" FontWeight="Bold"
                                           Foreground="#222222" FontFamily="Segoe UI"/>
                                <Border Height="1.5" Background="#BBBBBB" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Number badge "1" -->
                            <Grid HorizontalAlignment="Left" Margin="4,0,0,6"
                                  Width="26" Height="26"
                                  SnapsToDevicePixels="True" UseLayoutRounding="True">
                                <Ellipse Width="26" Height="26" Fill="White"
                                         Stroke="#111111" StrokeThickness="1.5"
                                         SnapsToDevicePixels="True"/>
                                <TextBlock Text="1" FontSize="13" FontWeight="Black"
                                           Foreground="#111111"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextOptions.TextFormattingMode="Display"
                                           SnapsToDevicePixels="True"/>
                            </Grid>

                            <!-- ── Route Card ── -->
                            <Border x:Name="DrvRouteCardBorder"
                                    BorderThickness="0" BorderBrush="Transparent"
                                    CornerRadius="0" Cursor="Hand"
                                    MouseLeftButtonUp="OnDrvRouteCardToggle">
                                <Border Height="165" CornerRadius="10" ClipToBounds="True">
                                    <Grid>
                                        <Image Source="/Assets/PMG3.png" Stretch="UniformToFill"/>
                                        <Border Background="#D80a0f1e"/>
                                        <Grid Margin="14,12,14,10">

                                            <!-- TOP: badges -->
                                            <Grid VerticalAlignment="Top">
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                    <Border Background="#3458e1" CornerRadius="5"
                                                            Padding="10,4" Margin="0,0,6,0">
                                                        <TextBlock Text="Publisher: Poli&amp;Co Official"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <Border Background="White" CornerRadius="5"
                                                            Padding="8,4">
                                                        <TextBlock Text="M200"
                                                                   FontSize="11" FontWeight="Black"
                                                                   Foreground="#3458e1"/>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0">
                                                        <Ellipse Width="8" Height="8" Fill="#28A745"
                                                                 VerticalAlignment="Center">
                                                            <Ellipse.Triggers>
                                                                <EventTrigger RoutedEvent="Loaded">
                                                                    <BeginStoryboard>
                                                                        <Storyboard RepeatBehavior="Forever">
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                From="1" To="0.15"
                                                                                Duration="0:0:0.9"
                                                                                AutoReverse="True"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Ellipse.Triggers>
                                                        </Ellipse>
                                                        <TextBlock Text=" RO.sv-1"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#28A745"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Image Source="/Assets/left icon.png"
                                                       Width="52" Height="52"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>

                                            <!-- MIDDLE: Route name -->
                                            <TextBlock Text="M200  Arad — Radna"
                                                       FontSize="22" FontWeight="Black"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       TextOptions.TextFormattingMode="Ideal"/>

                                            <!-- BOTTOM: Station timeline -->
                                            <Grid VerticalAlignment="Bottom">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="15"/>
                                                    </Grid.RowDefinitions>
                                                    <UniformGrid Grid.Row="0" Rows="1">
                                                        <TextBlock Text="Arad" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Glogovat" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Ghioroc" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Paulis hc." FontSize="10" Foreground="#AABBCC" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Paulis" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Radna" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    </UniformGrid>
                                                    <Grid Grid.Row="1">
                                                        <Border Height="1.5" Background="White" Opacity="0.35"
                                                                VerticalAlignment="Center" Margin="6,0,6,0"/>
                                                        <UniformGrid Rows="1">
                                                            <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="DrvDot1Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="DrvDot2Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="DrvDot3Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse Width="7" Height="7" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="DrvDot4Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="DrvDot5Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="DrvDot6Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                        </UniformGrid>
                                                    </Grid>
                                                </Grid>
                                            </Grid>

                                        </Grid>

                                        <Image Source="/Assets/logo.png"
                                               Width="80" Opacity="0.18"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,12,8"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Grid>
                                </Border>
                            </Border>

                            <!-- ── Card 2: Coming soon ── -->
                            <Border x:Name="DrvComingSoonCard"
                                    Height="70" CornerRadius="10" ClipToBounds="True"
                                    Margin="0,10,0,0" Opacity="0.7">
                                <Grid>
                                    <Image Source="/Assets/PMG4.png" Stretch="UniformToFill"/>
                                    <Border Background="#D00a0f1e"/>
                                    <Grid Margin="14,0,14,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="More routes" FontSize="16"
                                                       FontWeight="Black" Foreground="White"
                                                       TextOptions.TextFormattingMode="Ideal"/>
                                            <TextBlock Text="Coming soon..." FontSize="11"
                                                       Foreground="#AACCEE" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <Border Background="#2a2d3e" CornerRadius="5"
                                                Padding="8,3" HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Soon" FontSize="10"
                                                       FontWeight="Bold" Foreground="#888888"/>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ── Description panel (collapsed initially) ── DRV -->
                            <Border x:Name="DrvRouteDescPanel" Visibility="Collapsed"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <!-- Description text -->
                                    <StackPanel Margin="0,0,0,4">
                                        <TextBlock Text="M200 Arad – Radna"
                                                   FontSize="17" FontWeight="Black"
                                                   Foreground="#3458e1" Margin="0,0,0,10"
                                                   FontFamily="Segoe UI"
                                                   TextOptions.TextFormattingMode="Ideal"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                                   Foreground="#111111" LineHeight="22"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold">
                                            <Run Text="Developed by "/>
                                            <Run Text="Poli&amp;Co S.R.L." FontWeight="Black" Foreground="#070e2e"/>
                                            <Run Text=" and released in March 2026, this route spans approximately 40 km. It is located in the Crișana region of Romania and forms part of the Pan-European Corridor IV, featuring a high-speed connection towards Hungary. Designed to perfection, it stands as the most technologically advanced and intelligent route ever created."/>
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                                   Foreground="#111111" LineHeight="22"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                                   Margin="0,10,0,0">
                                            <Run Text="The route is officially licensed, fully integrated, and configured for multiplayer "/>
                                            <Run Text="(PC|MP)" FontWeight="Black" Foreground="#3458e1"/>
                                            <Run Text=" by the "/>
                                            <Run Text="PC|MP" FontWeight="Black" Foreground="#3458e1"/>
                                            <Run Text=" developers in collaboration with the publisher, "/>
                                            <Run Text="Poli&amp;Co." FontWeight="Black" Foreground="#070e2e"/>
                                            <Run Text=" It is optimized for both dispatchers and train drivers within the "/>
                                            <Run Text="PC|MP" FontWeight="Black" Foreground="#3458e1"/>
                                            <Run Text=" environment."/>
                                        </TextBlock>
                                        <Border Height="1" Background="#DDDDDD" Margin="0,14,0,14"/>
                                        <TextBlock Text="Key features:" FontSize="13"
                                                   FontWeight="Black" Foreground="#3458e1"
                                                   FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                                   Foreground="#111111" LineHeight="22"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                                   Margin="0,0,0,5">
                                            <Run FontWeight="Black" Foreground="#000000" Text="Complete Signaling &amp; Switch Control:"/>
                                            <Run Text=" Fully synchronized between all players in real-time."/>
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                                   Foreground="#111111" LineHeight="22"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                                   Margin="0,0,0,5">
                                            <Run FontWeight="Black" Foreground="#000000" Text="Integrated Communication:"/>
                                            <Run Text=" Built-in voice and text chat to connect with all players."/>
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                                   Foreground="#111111" LineHeight="22"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold">
                                            <Run FontWeight="Black" Foreground="#000000" Text="Dedicated Dispatch Zones:"/>
                                            <Run Text=" Custom-designed areas tailored for each dispatch post."/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Station list (Radna → Arad) -->
                                    <Border Height="1" Background="#DDDDDD" Margin="0,14,0,14"/>
                                    <TextBlock Text="Stations" FontSize="15" FontWeight="Black"
                                               Foreground="#111111" Margin="0,0,0,12"
                                               FontFamily="Segoe UI"/>

                                    <Grid>
                                        <Border Width="2" Background="#CCCCCC"
                                                HorizontalAlignment="Left" Margin="16,16,0,16"
                                                VerticalAlignment="Stretch"/>
                                        <StackPanel>

                                            <!-- 1. Radna (Terminal Arrival) -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="20" Height="20"
                                                         Fill="#CC1122" HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="Radna" FontSize="15" FontWeight="Bold" Foreground="#1a1a2e"/>
                                                    <TextBlock Text="Terminus · Arrival · Departure" FontSize="11" Foreground="#CC1122" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <Viewbox Grid.Column="2" Width="22" Height="22" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#CC1122"
                                                              Data="F1 M12,15.985 L15.182,12.803 L14.121,11.743 L12.75,13.114 L12.75,5.25 L11.25,5.25 L11.25,13.114 L9.879,11.743 L8.818,12.803 Z M18,17.25 L18,18.75 L6,18.75 L6,17.25 Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>

                                            <!-- 2. Paulis (Passing) -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="13" Height="13"
                                                         Fill="#070e2e" HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="Paulis" FontSize="15" FontWeight="Bold" Foreground="#1a1a2e"/>
                                                    <TextBlock Text="Passing station" FontSize="11" Foreground="#070e2e" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <Viewbox Grid.Column="2" Width="22" Height="22" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#070e2e"
                                                              Data="F1 M18,12.75 L18,11.25 L6,11.25 L6,12.75 Z M15.182,7.007 L12,10.189 L8.818,7.007 L9.879,5.947 L11.25,7.318 L11.25,2.25 L12.75,2.25 L12.75,7.318 L14.121,5.947 Z M8.818,16.993 L12,13.811 L15.182,16.993 L14.121,18.053 L12.75,16.682 L12.75,21.75 L11.25,21.75 L11.25,16.682 L9.879,18.053 Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>

                                            <!-- 3. Paulis hc. (Passing) -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="13" Height="13"
                                                         Fill="#070e2e" HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="Paulis hc." FontSize="15" FontWeight="Bold" Foreground="#1a1a2e"/>
                                                    <TextBlock Text="Passing station" FontSize="11" Foreground="#070e2e" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <Viewbox Grid.Column="2" Width="22" Height="22" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#070e2e"
                                                              Data="F1 M18,12.75 L18,11.25 L6,11.25 L6,12.75 Z M15.182,7.007 L12,10.189 L8.818,7.007 L9.879,5.947 L11.25,7.318 L11.25,2.25 L12.75,2.25 L12.75,7.318 L14.121,5.947 Z M8.818,16.993 L12,13.811 L15.182,16.993 L14.121,18.053 L12.75,16.682 L12.75,21.75 L11.25,21.75 L11.25,16.682 L9.879,18.053 Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>

                                            <!-- 4. Ghioroc (Passing) -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="13" Height="13"
                                                         Fill="#070e2e" HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="Ghioroc" FontSize="15" FontWeight="Bold" Foreground="#1a1a2e"/>
                                                    <TextBlock Text="Passing station" FontSize="11" Foreground="#070e2e" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <Viewbox Grid.Column="2" Width="22" Height="22" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#070e2e"
                                                              Data="F1 M18,12.75 L18,11.25 L6,11.25 L6,12.75 Z M15.182,7.007 L12,10.189 L8.818,7.007 L9.879,5.947 L11.25,7.318 L11.25,2.25 L12.75,2.25 L12.75,7.318 L14.121,5.947 Z M8.818,16.993 L12,13.811 L15.182,16.993 L14.121,18.053 L12.75,16.682 L12.75,21.75 L11.25,21.75 L11.25,16.682 L9.879,18.053 Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>

                                            <!-- 5. Glogovat (Passing) -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="13" Height="13"
                                                         Fill="#070e2e" HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="Glogovat" FontSize="15" FontWeight="Bold" Foreground="#1a1a2e"/>
                                                    <TextBlock Text="Passing station" FontSize="11" Foreground="#070e2e" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <Viewbox Grid.Column="2" Width="22" Height="22" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#070e2e"
                                                              Data="F1 M18,12.75 L18,11.25 L6,11.25 L6,12.75 Z M15.182,7.007 L12,10.189 L8.818,7.007 L9.879,5.947 L11.25,7.318 L11.25,2.25 L12.75,2.25 L12.75,7.318 L14.121,5.947 Z M8.818,16.993 L12,13.811 L15.182,16.993 L14.121,18.053 L12.75,16.682 L12.75,21.75 L11.25,21.75 L11.25,16.682 L9.879,18.053 Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>

                                            <!-- 6. Arad (Terminal Departure) -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="20" Height="20"
                                                         Fill="#CC1122" HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="Arad" FontSize="15" FontWeight="Bold" Foreground="#1a1a2e"/>
                                                    <TextBlock Text="Terminus · Arrival · Departure" FontSize="11" Foreground="#CC1122" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <Viewbox Grid.Column="2" Width="22" Height="22" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#CC1122"
                                                              Data="F1 M18,18.75 L18,17.25 L6,17.25 L6,18.75 Z M8.818,8.121 L12,4.939 L15.182,8.121 L14.121,9.182 L12.75,7.811 L12.75,15.675 L11.25,15.675 L11.25,7.811 L9.879,9.182 Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>

                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Go to set-up button (pinned bottom) -->
                    <Button x:Name="DrvProceedBtn" Grid.Row="2"
                            Visibility="Collapsed" Click="OnDrvProceedClick"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="DPBd" CornerRadius="8"
                                        Background="#3458e1" Padding="18,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Go to set-up!" FontSize="13"
                                                   FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text=" →" FontSize="13"
                                                   Foreground="White" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="DPBd" Property="Background" Value="#2040c0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ═══ RIGHT PANEL (global news / updates / guide) ═══ -->
                <Grid Grid.Column="1" Margin="32,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock FontSize="24" FontWeight="Black" Foreground="#000000"
                                   FontFamily="Segoe UI"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="About All in "/>
                            <Run Text="PC|MP" Foreground="#3458e1"/>
                        </TextBlock>
                        <TextBlock Text="News, updates and guides for dispatchers"
                                   FontSize="13" Foreground="#666666"
                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                   Margin="0,4,0,0"/>
                        <Border Height="1.5" Background="#BBBBBB" Margin="0,10,0,0"
                                HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Width" Value="220"/>
                                </Style>
                            </Border.Style>
                        </Border>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                                  Margin="0,14,0,0">
                        <StackPanel>

                            <!-- NEWS section -->
                            <StackPanel Margin="0,0,0,18">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Background="#3458e1" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="NEWS" FontSize="10" FontWeight="Black"
                                                   Foreground="White" FontFamily="Segoe UI"/>
                                    </Border>
                                    <TextBlock FontSize="15" FontWeight="Black"
                                               Foreground="#000000" Margin="10,0,0,0"
                                               VerticalAlignment="Center" FontFamily="Segoe UI">
                                        <Run Text="Last News "/>
                                        <Run Text="PC|MP" Foreground="#3458e1"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#111111" LineHeight="22" FontFamily="Segoe UI">
                                    <Run Text="Route M200 is now fully operational. New dispatcher training sessions available every weekend. Check your schedule."/>
                                </TextBlock>
                                <TextBlock Text="02.06.2026" FontSize="11" Foreground="#AAAAAA"
                                           Margin="0,6,0,0" FontFamily="Segoe UI"/>
                            </StackPanel>

                            <Border Height="1" Background="#DDDDDD" Margin="0,0,0,18"/>

                            <!-- UPDATES section -->
                            <StackPanel Margin="0,0,0,18">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Background="#28A745" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="UPDATE" FontSize="10" FontWeight="Black"
                                                   Foreground="White" FontFamily="Segoe UI"/>
                                    </Border>
                                    <TextBlock Text="Updates Incoming" FontSize="15" FontWeight="Black"
                                               Foreground="#000000" Margin="10,0,0,0"
                                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#111111" LineHeight="22" FontFamily="Segoe UI">
                                    <Run Text="Coming soon: real-time train tracking on the map, multi-dispatcher zones, and improved switch animations."/>
                                </TextBlock>
                                <TextBlock Text="Coming soon" FontSize="11" Foreground="#28A745"
                                           Margin="0,6,0,0" FontWeight="Black" FontFamily="Segoe UI"/>
                            </StackPanel>

                            <Border Height="1" Background="#DDDDDD" Margin="0,0,0,18"/>

                            <!-- GUIDE section -->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Background="#F5A623" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="GUIDE" FontSize="10" FontWeight="Black"
                                                   Foreground="White" FontFamily="Segoe UI"/>
                                    </Border>
                                    <TextBlock Text="Manuals &amp; Library" FontSize="15" FontWeight="Black"
                                               Foreground="#000000" Margin="10,0,0,0"
                                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#111111" LineHeight="22" FontFamily="Segoe UI">
                                    <Run Text="New to "/>
                                    <Run Text="PC|MP" Foreground="#3458e1" FontWeight="Black"/>
                                    <Run Text=" dispatching? Read our beginner guides: how to control switches, signal rules, and radio communication protocols."/>
                                </TextBlock>
                                <TextBlock Text="For new players" FontSize="11" Foreground="#F5A623"
                                           Margin="0,6,0,0" FontWeight="Black" FontFamily="Segoe UI"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ── Footer (universal) ── -->
            <Border Grid.Row="2" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Background="White">
                <Grid Margin="28,0,28,0">
                    <TextBlock Text="PC|MP Dispatch v1.0"
                               FontSize="11" Foreground="#CCCCCC"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Made with love" FontSize="11" Foreground="#888888"/>
                        <TextBlock Text=" ♥" FontSize="13" Foreground="#3458e1"
                                   Margin="3,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
</UserControl>
