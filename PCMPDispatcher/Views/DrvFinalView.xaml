<UserControl x:Class="PCMPDispatcher.DrvFinalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#ECEEF2">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar (universal — clock / server / players) -->
        <Border Grid.Row="0" Background="White" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
            <Grid Margin="28,0,28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="/Assets/logo.png" Width="160" Height="42"
                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,24,0" Width="114">
                        <TextBlock x:Name="FinalClockText" Text="00:00:00"
                                   FontSize="22" FontWeight="SemiBold" Foreground="#111111"
                                   FontFamily="Bahnschrift" HorizontalAlignment="Center"
                                   TextOptions.TextFormattingMode="Display" SnapsToDevicePixels="True"/>
                        <TextBlock x:Name="FinalDateText" Text="01.06.2026"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#555555"
                                   FontFamily="Bahnschrift SemiLight" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Border Width="1" Height="36" Background="#EEEEEE" Margin="0,0,24,0"/>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" Fill="#28A745" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#28A745" Opacity="0.8" BlurRadius="6" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="RO.sv-1" FontSize="14" FontWeight="Bold"
                                       Foreground="#000000" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Active" FontSize="11" Foreground="#28A745" Margin="16,0,0,0"/>
                    </StackPanel>
                    <Border Width="1" Height="36" Background="#EEEEEE" Margin="0,0,24,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Active players" FontSize="11" Foreground="#888888"/>
                        <TextBlock x:Name="SbOnlineCount" Text="… / 40" FontSize="20" FontWeight="Black" Foreground="#3458e1"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,150,0">
                    <!-- Шестерёнка громкости — такой же стиль как Back, перед ней -->
                    <Button x:Name="FinalVolumeGearBtn"
                            Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                            FocusVisualStyle="{x:Null}" UseLayoutRounding="True" SnapsToDevicePixels="True"
                            Click="OnVolumeGearClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="GBd" BorderBrush="#3458e1" BorderThickness="1.5"
                                        CornerRadius="0" Padding="{TemplateBinding Padding}" Background="#F0F4FF">
                                    <TextBlock x:Name="GBt" FontFamily="Segoe MDL2 Assets" Text="&#xE713;"
                                               FontSize="16" FontWeight="Normal"
                                               TextOptions.TextFormattingMode="Ideal"
                                               TextOptions.TextRenderingMode="ClearType"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#3458e1"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="GBd" Property="Background" Value="#3458e1"/>
                                        <Setter TargetName="GBt" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Popup слайдера — привязан к кнопке шестерёнки в сайдбаре -->
                    <Popup x:Name="FinalVolumePopup"
                           PlacementTarget="{Binding ElementName=FinalVolumeGearBtn}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" VerticalOffset="4">
                        <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                CornerRadius="0" Padding="16,12" Width="240">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" Opacity="0.13" ShadowDepth="3"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;"
                                               FontSize="13" Foreground="#3458e1" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Chat Volume" FontSize="12"
                                               FontWeight="Bold" Foreground="#222222"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                                <Slider x:Name="FinalVolumeSlider"
                                        Minimum="0" Maximum="100" Value="80"
                                        SmallChange="1" LargeChange="10" Height="18"
                                        ValueChanged="OnVolumeChanged">
                                    <Slider.Template>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid>
                                                <Track x:Name="PART_Track">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="Slider.DecreaseLarge">
                                                            <RepeatButton.Template>
                                                                <ControlTemplate TargetType="RepeatButton">
                                                                    <Border Height="3" Background="#3458e1" CornerRadius="0" VerticalAlignment="Center"/>
                                                                </ControlTemplate>
                                                            </RepeatButton.Template>
                                                        </RepeatButton>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="Slider.IncreaseLarge">
                                                            <RepeatButton.Template>
                                                                <ControlTemplate TargetType="RepeatButton">
                                                                    <Border Height="3" Background="#E0E0E0" CornerRadius="0" VerticalAlignment="Center"/>
                                                                </ControlTemplate>
                                                            </RepeatButton.Template>
                                                        </RepeatButton>
                                                    </Track.IncreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb Width="11" Height="11" Cursor="Hand">
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Ellipse Width="11" Height="11" Fill="#3458e1"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Slider.Template>
                                </Slider>
                                <Grid Margin="0,6,0,0">
                                    <TextBlock Text="0" FontSize="10" Foreground="#BBBBBB" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="FinalVolumeLabel" Text="80%"
                                               FontSize="11" FontWeight="Bold" Foreground="#3458e1"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="100" FontSize="10" Foreground="#BBBBBB" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Button Padding="16,8" Click="OnDrvFinalBack_Click" Cursor="Hand"
                            FocusVisualStyle="{x:Null}" UseLayoutRounding="True" SnapsToDevicePixels="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" BorderBrush="#3458e1" BorderThickness="1.5"
                                        CornerRadius="0" Padding="{TemplateBinding Padding}" Background="#F0F4FF">
                                    <TextBlock x:Name="Bt" Text="&#8592; Back" FontSize="13" FontWeight="Black"
                                               Foreground="#3458e1" FontFamily="Segoe UI"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3458e1"/>
                                        <Setter TargetName="Bt" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Document -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center" Margin="0,26,0,44">
                <!-- A4 sheet -->
                <Border Width="840" Background="White" BorderBrush="#DDDDDD" BorderThickness="1"
                        Padding="64,52,64,42">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.14" BlurRadius="22" ShadowDepth="3"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel x:Name="DrvSheetContent"/>

                        <!-- Connect button row -->
                        <Grid Margin="0,24,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border x:Name="DrvConnectBtn" Background="#111111" Cursor="Hand" Padding="26,12"
                                        MouseLeftButtonUp="OnConnectClick">
                                    <TextBlock x:Name="DrvConnectText" Text="Connect to PC|MP" FontSize="14"
                                               FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                </Border>
                                <Border x:Name="DrvExitBtn" Visibility="Collapsed" Background="#CC1122" Cursor="Hand"
                                        Padding="13,11" Margin="10,0,0,0" MouseLeftButtonUp="OnDisconnectClick"
                                        ToolTip="Disconnect">
                                    <Viewbox Width="20" Height="20">
                                        <Canvas Width="32" Height="32">
                                            <Path Fill="White" Data="M23.93,25 v3 h-16 V4 h16 V7 h2 V3 a1,1,0,0,0,-1,-1 h-18 a1,1,0,0,0,-1,1 V29 a1,1,0,0,0,1,1 h18 a1,1,0,0,0,1,-1 V25 Z"/>
                                            <Line X1="15.92" Y1="16" X2="28.92" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="28.92" Y1="16" X2="24.92" Y2="12" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="28.92" Y1="16" X2="24.92" Y2="20" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#DDDDDD" Margin="0,18,0,8"/>
                        <TextBlock Text="Approved by PC|MP." FontSize="12" FontWeight="Bold"
                                   Foreground="#AAAAAA" HorizontalAlignment="Left" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Centered notice (e.g. blocked Back while connected) -->
        <Border x:Name="FinalNotice" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="30" Opacity="0"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#0f1117" CornerRadius="10" Padding="28,16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.35" BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>
            <TextBlock x:Name="FinalNoticeText" Text="" Foreground="White" FontSize="15"
                       FontWeight="Bold" FontFamily="Segoe UI"/>
        </Border>
    </Grid>
</UserControl>
