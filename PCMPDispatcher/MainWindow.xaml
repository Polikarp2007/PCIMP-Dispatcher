                                    <Run Text="Coming soon: real-time train tracking on the map, multi-dispatcher zones, and improved switch animations."/>
                                </TextBlock>
                                <TextBlock Text="Coming soon" FontSize="11" Foreground="#28A745"
                                           Margin="0,6,0,0" FontWeight="Black" FontFamily="Segoe UI"/>
                            </StackPanel>

                            <Border Height="1" Background="#DDDDDD" Margin="0,0,0,18"/>

                            <!-- GUIDE section -->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Background="#F5A623" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="GUIDE" FontSize="10" FontWeight="Black"
                                                   Foreground="White" FontFamily="Segoe UI"/>
                                    </Border>
                                    <TextBlock Text="Manuals &amp; Library" FontSize="15" FontWeight="Black"
                                               Foreground="#000000" Margin="10,0,0,0"
                                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#111111" LineHeight="22" FontFamily="Segoe UI">
                                    <Run Text="New to "/>
                                    <Run Text="PC|MP" Foreground="#3458e1" FontWeight="Black"/>
                                    <Run Text=" dispatching? Read our beginner guides: how to control switches, signal rules, and radio communication protocols."/>
                                </TextBlock>
                                <TextBlock Text="For new players" FontSize="11" Foreground="#F5A623"
                                           Margin="0,6,0,0" FontWeight="Black" FontFamily="Segoe UI"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ── Footer (universal) ── -->
            <Border Grid.Row="2" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Background="White">
                <Grid Margin="28,0,28,0">
                    <TextBlock Text="PC|MP Dispatch v1.0"
                               FontSize="11" Foreground="#CCCCCC"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Made with love" FontSize="11" Foreground="#888888"/>
                        <TextBlock Text=" ♥" FontSize="13" Foreground="#3458e1"
                                   Margin="3,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 2-D2 — DRIVER SET-UP (Step 1: schedule)          -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="DrvSetupPage" Background="White" Visibility="Collapsed" Panel.ZIndex="5"
              MouseMove="OnSetupStageHover">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Grid.Resources>
                <Style x:Key="FieldComboItem" TargetType="ComboBoxItem">
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#222222"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ib" Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="ib" Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="FieldBox" TargetType="TextBox">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="Foreground" Value="#222222"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="CaretBrush" Value="#3458e1"/>
                    <Setter Property="Padding" Value="10,0,10,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border x:Name="bd" Background="White" BorderBrush="#DADFEA"
                                        BorderThickness="1.5" CornerRadius="6">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#B9C2D8"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#3458e1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="FieldCombo" TargetType="ComboBox">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#222222"/>
                    <Setter Property="ItemContainerStyle" Value="{StaticResource FieldComboItem}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBox">
                                <Grid>
                                    <ToggleButton Focusable="False" ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="bd" Background="White" BorderBrush="#DADFEA"
                                                        BorderThickness="1.5" CornerRadius="6">
                                                    <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                          Margin="0,0,12,0" Data="M0,0 L10,0 L5,6 Z" Fill="#9aa3b5"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="#B9C2D8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="11,0,26,0" VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <Popup x:Name="PART_Popup" Placement="Bottom"
                                           IsOpen="{TemplateBinding IsDropDownOpen}"
                                           AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                        <Border Background="White" BorderBrush="#DADFEA" BorderThickness="1.5"
                                                CornerRadius="6" Margin="0,4,0,4"
                                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" ShadowDepth="2"/>
                                            </Border.Effect>
                                            <ScrollViewer MaxHeight="260">
                                                <StackPanel IsItemsHost="True" Margin="0,4,0,4"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="StepBtn" TargetType="Button">
                    <Setter Property="Width" Value="34"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="#3458e1"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="sb" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="sb" Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="GreenCheck" TargetType="CheckBox">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="CheckBox">
                                <StackPanel Orientation="Horizontal" Background="Transparent">
                                    <Border x:Name="box" Width="20" Height="20" CornerRadius="3"
                                            BorderBrush="#C8CDDA" BorderThickness="1.5" Background="White"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="chk" Text="&#10003;" FontSize="13" FontWeight="Black"
                                                   Foreground="#28A745" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Border>
                                    <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="box" Property="BorderBrush" Value="#28A745"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="box" Property="BorderBrush" Value="#28A745"/>
                                        <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <!-- ── Top bar ── -->
            <Border Grid.Row="0" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Background="White">
                <Grid Margin="28,0,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Source="Assets/logo.png" Width="160" Height="42"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>

                    <!-- Stage labels centered over each half -->
                    <Grid Grid.Column="0" Grid.ColumnSpan="3" IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="DrvStep1Num" Text="1" FontSize="13" FontWeight="Black" Foreground="White"
                                       Width="24" Height="24" TextAlignment="Center" Padding="0,3,0,0"
                                       Background="#3458e1"/>
                            <TextBlock x:Name="DrvStep1Lbl" Text="Configuration Page" FontSize="14" FontWeight="Bold"
                                       Foreground="#111111" VerticalAlignment="Center" Margin="9,0,0,0" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="DrvStep2Num" Text="2" FontSize="13" FontWeight="Black" Foreground="#BBBBBB"
                                       Width="24" Height="24" TextAlignment="Center" Padding="0,3,0,0"
                                       Background="#F0F0F0"/>
                            <TextBlock x:Name="DrvStep2Lbl" Text="Consist Page" FontSize="14" FontWeight="Bold"
                                       Foreground="#BBBBBB" VerticalAlignment="Center" Margin="9,0,0,0" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,150,0">
                        <Button Padding="16,8" Click="OnDrvSetupBack_Click" Cursor="Hand"
                                FocusVisualStyle="{x:Null}"
                                UseLayoutRounding="True" SnapsToDevicePixels="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" BorderBrush="#3458e1" BorderThickness="1.5"
                                            CornerRadius="0" Padding="{TemplateBinding Padding}" Background="#F0F4FF">
                                        <TextBlock x:Name="Bt" Text="&#8592; Back" FontSize="13" FontWeight="Black"
                                                   Foreground="#3458e1" FontFamily="Segoe UI"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3458e1"/>
                                            <Setter TargetName="Bt" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main 2-column (50/50) ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="1" Background="#F0F0F0"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"/>

                <!-- ═══ LEFT: schedule builder ═══ -->
                <Grid Grid.Column="0" Margin="28,22,28,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,18">
                        <TextBlock Text="Plan your run" FontSize="26" FontWeight="Black" Foreground="#000000"
                                   TextOptions.TextFormattingMode="Ideal"/>
                        <TextBlock Text="Build your plan for route M200 Arad - Radna" FontSize="15"
                                   Foreground="#666666" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Steps 1-4 -->
                    <StackPanel Grid.Row="1">

                        <!-- 1. Train number -->
                        <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,0,0,3"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="1." Foreground="#3458e1"/><Run Text="  Train number" Foreground="#111111"/>
                        </TextBlock>
                        <TextBlock Text="Pick the class and number of your train." FontSize="12.5"
                                   Foreground="#999999" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <ComboBox x:Name="DrvTrainType" Style="{StaticResource FieldCombo}"
                                      Width="88" Height="38" Margin="0,0,8,0">
                                <ComboBoxItem Content="R"/>
                                <ComboBoxItem Content="RE"/>
                                <ComboBoxItem Content="IRN"/>
                                <ComboBoxItem Content="IR"/>
                                <ComboBoxItem Content="IC"/>
                                <ComboBoxItem Content="RM"/>
                            </ComboBox>
                            <TextBox x:Name="DrvTrainNum" Style="{StaticResource FieldBox}"
                                     Width="120" Height="38" FontSize="15" FontWeight="Bold"
                                     MaxLength="6" PreviewTextInput="OnDigitsOnly"/>
                        </StackPanel>

                        <!-- 2. Direction -->
                        <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,0,0,3"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="2." Foreground="#3458e1"/><Run Text="  Direction" Foreground="#111111"/>
                        </TextBlock>
                        <TextBlock Text="Choose where you'll travel from and to." FontSize="12.5"
                                   Foreground="#999999" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                        <ComboBox x:Name="DrvDirection" Style="{StaticResource FieldCombo}"
                                  Width="220" Height="38" HorizontalAlignment="Left" Margin="0,0,0,20"
                                  SelectionChanged="OnDrvDirectionChanged">
                            <ComboBoxItem Content="Radna &#8594; Arad"/>
                            <ComboBoxItem Content="Arad &#8594; Radna"/>
                        </ComboBox>

                        <!-- 3. Departure platform -->
                        <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,0,0,3"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="3." Foreground="#3458e1"/><Run Text="  Departure platform" Foreground="#111111"/>
                        </TextBlock>
                        <TextBlock x:Name="DrvPlatformDesc" Text="Choose the platform you'll depart from."
                                   FontSize="12.5" Foreground="#999999" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,10"/>
                        <ComboBox x:Name="DrvPlatform" Style="{StaticResource FieldCombo}"
                                  Width="220" Height="38" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                        <!-- 4. Departure time -->
                        <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,0,0,3"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="4." Foreground="#3458e1"/><Run Text="  Departure time" Foreground="#111111"/>
                        </TextBlock>
                        <TextBlock Text="Set the approximate departure time from the first station." FontSize="12.5"
                                   Foreground="#999999" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBox x:Name="DrvHH" Style="{StaticResource FieldBox}" Width="60" Height="38"
                                     FontSize="17" FontWeight="Bold" MaxLength="2" Text="13" Padding="0"
                                     TextAlignment="Center" PreviewTextInput="OnDigitsOnly"/>
                            <TextBlock Text=":" FontSize="20" FontWeight="Black" Foreground="#111111"
                                       VerticalAlignment="Center" Margin="8,0,8,0"/>
                            <TextBox x:Name="DrvMM" Style="{StaticResource FieldBox}" Width="60" Height="38"
                                     FontSize="17" FontWeight="Bold" MaxLength="2" Text="00" Padding="0"
                                     TextAlignment="Center" PreviewTextInput="OnDigitsOnly"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 5. Station stops (fills remaining height) -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,0,0,3"
                                       TextOptions.TextFormattingMode="Ideal">
                                <Run Text="5." Foreground="#3458e1"/><Run Text="  Station stops" Foreground="#111111"/>
                            </TextBlock>
                            <TextBlock Text="Set how long you'll stop at each station." FontSize="12.5"
                                       Foreground="#999999" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,10" FontFamily="Segoe UI"
                                       FontWeight="SemiBold">
                                <Run Text="Stopping at every station is " Foreground="#888888"/><Run Text="mandatory" Foreground="#555555" FontWeight="Black"/><Run Text=" on " Foreground="#888888"/><Run Text="PC|MP" Foreground="#3458e1" FontWeight="Black"/><Run Text="." Foreground="#888888"/>
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#D5D9E2" BorderThickness="1" CornerRadius="0"
                                Background="Transparent" Padding="18,12" Margin="0,0,0,0">
                            <UniformGrid x:Name="DrvDwellPanel" Columns="1"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══ RIGHT: consist configuration ═══ -->
                <Grid Grid.Column="1" Margin="28,22,28,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,18">
                        <TextBlock FontSize="26" FontWeight="Black" Foreground="#000000"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="Build your train" Foreground="#000000"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="15" Foreground="#666666" FontWeight="SemiBold"
                                   Margin="0,5,0,0" FontFamily="Segoe UI">
                            <Run Text="Set up the consist you'll be identified by on "/><Run Text="PC|MP" Foreground="#3458e1" FontWeight="Black"/><Run Text=" and to other players."/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Steps 1-2 -->
                    <StackPanel Grid.Row="1">

                        <!-- 1. Locomotive -->
                        <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,0,0,3"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="1." Foreground="#3458e1"/><Run Text="  Locomotive" Foreground="#111111"/>
                        </TextBlock>
                        <TextBlock Text="Choose the locomotive that heads your train." FontSize="12.5"
                                   Foreground="#999999" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                        <ComboBox x:Name="DrvLocoCombo" Style="{StaticResource FieldCombo}"
                                  Width="300" Height="38" HorizontalAlignment="Left" Margin="0,0,0,22"
                                  SelectionChanged="OnConsistChanged">
                            <ComboBoxItem Content="L-PC 013-EA-060 (PCIMP)"/>
                        </ComboBox>

                        <!-- 2. Wagons -->
                        <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,0,0,3"
                                   TextOptions.TextFormattingMode="Ideal">
                            <Run Text="2." Foreground="#3458e1"/><Run Text="  Wagons" Foreground="#111111"/>
                        </TextBlock>
                        <TextBlock Text="Pick how many wagons (1–6) and their type." FontSize="12.5"
                                   Foreground="#999999" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <!-- count stepper -->
                            <Border BorderBrush="#D5D9E2" BorderThickness="1" CornerRadius="0"
                                    Background="White" Height="38" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource StepBtn}" Content="&#8722;" Click="OnWagonMinus"/>
                                    <Border Width="1" Background="#E6E9F1"/>
                                    <TextBlock x:Name="DrvWagonCount" Text="3" Width="46" FontSize="16"
                                               FontWeight="Bold" Foreground="#111111" TextAlignment="Center"
                                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                    <Border Width="1" Background="#E6E9F1"/>
                                    <Button Style="{StaticResource StepBtn}" Content="+" Click="OnWagonPlus"/>
                                </StackPanel>
                            </Border>
                            <ComboBox x:Name="DrvWagonType" Style="{StaticResource FieldCombo}"
                                      Width="300" Height="38" Margin="12,0,0,0" VerticalAlignment="Center"
                                      SelectionChanged="OnConsistChanged">
                                <ComboBoxItem Content="VGPC 080-PAS-098 (PCIMP)"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- Consist preview + additional options -->
                    <ScrollViewer Grid.Row="2" Margin="0,20,0,0" VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Your consist" FontSize="14" FontWeight="Bold" Foreground="#222222"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="DrvConsistSummary" Text="" FontSize="12.5" Foreground="#999999"
                                           FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Border BorderBrush="#D5D9E2" BorderThickness="1" CornerRadius="0"
                                    Background="White" Height="96">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                              Padding="16,0">
                                    <StackPanel x:Name="DrvConsistStrip" Orientation="Horizontal"
                                                VerticalAlignment="Center"/>
                                </ScrollViewer>
                            </Border>

                            <!-- 3. Additional options -->
                            <TextBlock FontSize="18" FontWeight="Black" FontFamily="Segoe UI" Margin="0,24,0,3"
                                       TextOptions.TextFormattingMode="Ideal">
                                <Run Text="3." Foreground="#3458e1"/><Run Text="  Additional options" Foreground="#111111"/>
                            </TextBlock>
                            <TextBlock Text="Toggle the extras you want for this run." FontSize="12.5"
                                       Foreground="#999999" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,14"/>

                            <CheckBox x:Name="DrvOptRadio" Style="{StaticResource GreenCheck}" Margin="0,0,0,4">
                                <TextBlock Text="I speak on the radio" FontSize="14" FontWeight="Bold"
                                           Foreground="#1a1a2e" FontFamily="Segoe UI"/>
                            </CheckBox>
                            <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#999999" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Margin="30,0,0,16"
                                       Text="Enables live voice comms when a dispatcher is on the route — they may call you and talk over the intercom."/>

                            <CheckBox x:Name="DrvOptTextOnly" Style="{StaticResource GreenCheck}" Margin="0,0,0,4">
                                <TextBlock Text="I'm text-chat only" FontSize="14" FontWeight="Bold"
                                           Foreground="#1a1a2e" FontFamily="Segoe UI"/>
                            </CheckBox>
                            <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#999999" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Margin="30,0,0,16">
                                <Run Text="With a dispatcher present you'll communicate only via text — they'll send commands and info to your "/><Run Text="PC|MP" Foreground="#3458e1" FontWeight="Black"/><Run Text=" HUD chat."/>
                            </TextBlock>

                            <CheckBox x:Name="DrvOptPriority" Style="{StaticResource GreenCheck}" Margin="0,0,0,4">
                                <TextBlock Text="I need priority departure" FontSize="14" FontWeight="Bold"
                                           Foreground="#1a1a2e" FontFamily="Segoe UI"/>
                            </CheckBox>
                            <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#999999" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Margin="30,0,0,8"
                                       Text="Helps when the session is full but you want to leave ASAP — the server or dispatcher will clear you to depart as soon as possible. It won't always help much; enable it if you're in a hurry (work, study) and just want to get going quickly :)"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Go to Final Page -->
                    <Button Grid.Row="3" Click="OnDrvGoFinal" HorizontalAlignment="Right" Cursor="Hand"
                            FocusVisualStyle="{x:Null}" Margin="0,16,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="FBd" CornerRadius="8" Background="#3458e1" Padding="22,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Go to Final Page" FontSize="14" FontWeight="Bold"
                                                   Foreground="White" FontFamily="Segoe UI"/>
                                        <TextBlock Text=" &#8594;" FontSize="14" Foreground="White" Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FBd" Property="Background" Value="#2040c0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>

            <!-- ── Footer ── -->
            <Border Grid.Row="2" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Background="White">
                <Grid Margin="28,0,28,0">
                    <TextBlock Text="PC|MP Dispatch v1.0" FontSize="11" Foreground="#CCCCCC"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Made with love" FontSize="11" Foreground="#888888"/>
                        <TextBlock Text=" &#9829;" FontSize="13" Foreground="#3458e1" Margin="3,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 2-D3 — DRIVER FINAL (run sheet)                   -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="DrvFinalPage" Background="#ECEEF2" Visibility="Collapsed" Panel.ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
                <Grid Margin="28,0,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="Assets/logo.png" Width="150" Height="40"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="3" FontSize="13" FontWeight="Black" Foreground="White"
                                   Width="24" Height="24" TextAlignment="Center" Padding="0,3,0,0"
                                   Background="#3458e1"/>
                        <TextBlock Text="Final Page" FontSize="14" FontWeight="Bold" Foreground="#111111"
                                   VerticalAlignment="Center" Margin="9,0,0,0" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,150,0">
                        <Button Padding="16,8" Click="OnDrvFinalBack_Click" Cursor="Hand"
                                FocusVisualStyle="{x:Null}" UseLayoutRounding="True" SnapsToDevicePixels="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" BorderBrush="#3458e1" BorderThickness="1.5"
                                            CornerRadius="0" Padding="{TemplateBinding Padding}" Background="#F0F4FF">
                                        <TextBlock x:Name="Bt" Text="&#8592; Back" FontSize="13" FontWeight="Black"
                                                   Foreground="#3458e1" FontFamily="Segoe UI"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3458e1"/>
                                            <Setter TargetName="Bt" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Document -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel HorizontalAlignment="Center" Margin="0,26,0,44">
                    <!-- A4 sheet -->
                    <Border Width="840" Background="White" BorderBrush="#DDDDDD" BorderThickness="1"
                            Padding="64,52,64,42">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.14" BlurRadius="22" ShadowDepth="3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel x:Name="DrvSheetContent"/>

                            <!-- Connect button (+ exit) — sits above the approval divider -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                                <Border x:Name="DrvConnectBtn" Background="#111111" Cursor="Hand" Padding="26,12"
                                        MouseLeftButtonUp="OnConnectClick">
                                    <TextBlock x:Name="DrvConnectText" Text="Connect to PC|MP" FontSize="14"
                                               FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                                </Border>
                                <Border x:Name="DrvExitBtn" Visibility="Collapsed" Background="#CC1122" Cursor="Hand"
                                        Padding="13,11" Margin="10,0,0,0" MouseLeftButtonUp="OnDisconnectClick"
                                        ToolTip="Disconnect">
                                    <Viewbox Width="20" Height="20">
                                        <Canvas Width="32" Height="32">
                                            <Path Fill="White" Data="M23.93,25 v3 h-16 V4 h16 V7 h2 V3 a1,1,0,0,0,-1,-1 h-18 a1,1,0,0,0,-1,1 V29 a1,1,0,0,0,1,1 h18 a1,1,0,0,0,1,-1 V25 Z"/>
                                            <Line X1="15.92" Y1="16" X2="28.92" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="28.92" Y1="16" X2="24.92" Y2="12" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="28.92" Y1="16" X2="24.92" Y2="20" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </StackPanel>

                            <Border Height="1" Background="#DDDDDD" Margin="0,18,0,8"/>
                            <TextBlock Text="Approved by PC|MP." FontSize="12" FontWeight="Bold"
                                       Foreground="#AAAAAA" HorizontalAlignment="Left" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 3 — DISPATCHERS CONFIG                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="StationPage" Background="White" Visibility="Collapsed" Panel.ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Background="White">
                <Grid Margin="28,0,28,0">
                    <Image Source="Assets/logo.png" Width="160" Height="42"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
                    <!-- Back -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,150,0">
                        <Button Padding="16,8" Click="OnStationBack_Click"
                                Cursor="Hand"
                                UseLayoutRounding="True" SnapsToDevicePixels="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" BorderBrush="#3458e1" BorderThickness="1.5"
                                            CornerRadius="0" Padding="{TemplateBinding Padding}"
                                            Background="#F0F4FF"
                                            UseLayoutRounding="True"
                                            SnapsToDevicePixels="True">
                                        <TextBlock x:Name="BtnTxt" Text="← Back" FontSize="13"
                                                   FontWeight="Black" Foreground="#3458e1"
                                                   FontFamily="Segoe UI"
                                                   UseLayoutRounding="True"
                                                   SnapsToDevicePixels="True"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3458e1"/>
                                            <Setter TargetName="BtnTxt" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2-column content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="12*"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical separator -->
                <Border Grid.Column="0" Width="1" Background="#F0F0F0"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"/>

                <!-- LEFT: Dispatchers config -->
                <Grid Grid.Column="0" Margin="20,24,16,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <!-- Title — same style as "Ready to DISPATCH?" on main page -->
                        <TextBlock Text="Dispatchers config"
                                   FontSize="26" FontWeight="Black" Foreground="#000000"
                                   FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal"/>
                        <Border Height="2" Background="#BBBBBB" HorizontalAlignment="Left"
                                Width="270" Margin="0,8,0,0"/>

                        <!-- Description -->
                        <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#555555" LineHeight="21" FontFamily="Segoe UI"
                                   Margin="0,12,0,0">
                            <Run Text="Browse active stations, check current player count, dispatcher shifts and live status across "/>
                            <Run Text="PC|MP" FontWeight="Black" Foreground="#3458e1"/>
                            <Run Text=". Select a station below to view full details and take over dispatching."/>
                        </TextBlock>

                        <!-- Route card — full replica, scaled for this panel -->
                        <Border Height="145" CornerRadius="10" ClipToBounds="True" Margin="0,14,0,0">
                            <Grid>
                                <Image Source="Assets/PMG3.png" Stretch="UniformToFill"/>
                                <Border Background="#D80a0f1e"/>
                                <Grid Margin="14,10,14,10">

                                    <!-- TOP: Publisher badge + M200 + server + icon -->
                                    <Grid VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                            <Border Background="#3458e1" CornerRadius="5"
                                                    Padding="10,4" Margin="0,0,6,0">
                                                <TextBlock Text="Publisher: Poli&amp;Co Official"
                                                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <Border Background="White" CornerRadius="5" Padding="8,4">
                                                <TextBlock Text="M200" FontSize="11" FontWeight="Black"
                                                           Foreground="#3458e1"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0">
                                                <Ellipse Width="8" Height="8" Fill="#28A745"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetProperty="Opacity"
                                                                        From="1" To="0.15"
                                                                        Duration="0:0:0.9"
                                                                        AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Ellipse.Triggers>
                                                </Ellipse>
                                                <TextBlock Text=" RO.sv-1" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="#28A745"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Image Source="Assets/left icon.png"
                                               Width="44" Height="44"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Grid>

                                    <!-- MIDDLE: Route name -->
                                    <TextBlock Text="M200  Arad — Radna"
                                               FontSize="19" FontWeight="Black"
                                               Foreground="White" VerticalAlignment="Center"
                                               TextOptions.TextFormattingMode="Ideal"/>

                                    <!-- BOTTOM: Station timeline — chaser animation -->
                                    <Grid VerticalAlignment="Bottom">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="15"/>
                                        </Grid.RowDefinitions>
                                        <UniformGrid Grid.Row="0" Rows="1">
                                            <TextBlock Text="Arad" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Glogovat" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Ghioroc" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Paulis hc." FontSize="10" Foreground="#AABBCC" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Paulis" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Radna" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </UniformGrid>
                                        <Grid Grid.Row="1">
                                            <Border Height="1.5" Background="White" Opacity="0.35"
                                                    VerticalAlignment="Center" Margin="6,0,6,0"/>
                                            <UniformGrid Rows="1">
                                                <Ellipse x:Name="MiniDot1" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Fill><SolidColorBrush x:Name="MiniDot1Brush" Color="#3458e1"/></Ellipse.Fill>
                                                </Ellipse>
                                                <Ellipse x:Name="MiniDot2" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Fill><SolidColorBrush x:Name="MiniDot2Brush" Color="#3458e1"/></Ellipse.Fill>
                                                </Ellipse>
                                                <Ellipse x:Name="MiniDot3" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Fill><SolidColorBrush x:Name="MiniDot3Brush" Color="#3458e1"/></Ellipse.Fill>
                                                </Ellipse>
                                                <Ellipse x:Name="MiniDot4" Width="7" Height="7" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Fill><SolidColorBrush x:Name="MiniDot4Brush" Color="#3458e1"/></Ellipse.Fill>
                                                </Ellipse>
                                                <Ellipse x:Name="MiniDot5" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Fill><SolidColorBrush x:Name="MiniDot5Brush" Color="#3458e1"/></Ellipse.Fill>
                                                </Ellipse>
                                                <Ellipse x:Name="MiniDot6" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Fill><SolidColorBrush x:Name="MiniDot6Brush" Color="#3458e1"/></Ellipse.Fill>
                                                </Ellipse>
                                            </UniformGrid>
                                        </Grid>
                                    </Grid>
                                </Grid>
                                <!-- Logo watermark -->
                                <Image Source="Assets/logo.png" Width="70" Opacity="0.18"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Margin="0,0,12,8"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Station list — fills full height with even spacing -->
                    <Grid Grid.Row="1">
                        <!-- Vertical connecting line -->
                        <Border Width="2" Background="#DDDDDD"
                                HorizontalAlignment="Left" Margin="15,0,0,0"
                                VerticalAlignment="Stretch"/>
                        <Grid x:Name="SetupStationList"/>
                    </Grid>
                </Grid>

                <!-- RIGHT: Station detail — layered background support -->
                <Grid Grid.Column="1">
                    <!-- Layer 0: station background image (set from code) -->
                    <Border x:Name="StationDetailBg" Background="White"/>
                    <!-- Layer 1: dark overlay (set from code) -->
                    <Border x:Name="StationDetailDark" Background="Transparent"/>
                    <!-- Layer 2: scrollable content -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent">
                        <StackPanel x:Name="StationDetailPanel" Margin="32,24,32,24">
                            <!-- Empty state prompt — populated by code-behind -->
                            <StackPanel x:Name="StationDetailPrompt" Margin="0,60,0,0">
                                <TextBlock Text="Select a station"
                                           FontSize="30" FontWeight="Black" Foreground="#DDDDDD"
                                           FontFamily="Segoe UI"
                                           TextOptions.TextFormattingMode="Ideal"/>
                                <TextBlock Text="← from the list on the left"
                                           FontSize="15" FontWeight="SemiBold" Foreground="#CCCCCC"
                                           FontFamily="Segoe UI" Margin="0,7,0,0"/>
                                <TextBlock Text="to view details and take over dispatching"
                                           FontSize="15" FontWeight="SemiBold" Foreground="#CCCCCC"
                                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Layer 3: marching ants border (top of stack, no hit-test) -->
                    <Canvas x:Name="StationDetailCanvas" IsHitTestVisible="False"/>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Background="White">
                <Grid Margin="28,0,28,0">
                    <TextBlock Text="PC|MP Dispatch v1.0" FontSize="11" Foreground="#CCCCCC"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Made with love" FontSize="11" Foreground="#888888"/>
                        <TextBlock Text=" ♥" FontSize="13" Foreground="#3458e1" Margin="3,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 4 — DISPATCHER CONSOLE                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="ConsolePage" Background="White" Visibility="Collapsed" Panel.ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Top bar ── -->
            <Border Grid.Row="0" Background="White" BorderThickness="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="24,0,24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── LEFT: Logo + title + station ── -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/logo.png" Width="140" Height="38"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
                            <Border Width="1.5" Height="38" Background="#E0E0E0" Margin="18,0,18,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <!-- PC|MP Dispatcher -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PC|MP" FontSize="14" FontWeight="Black"
                                               Foreground="#3458e1" FontFamily="Segoe UI"
                                               TextOptions.TextFormattingMode="Ideal"/>
                                    <TextBlock Text=" Dispatcher" FontSize="14" FontWeight="Black"
                                               Foreground="#111111" FontFamily="Segoe UI"
                                               TextOptions.TextFormattingMode="Ideal"/>
                                </StackPanel>
                                <!-- Station: PAULIS with live dot -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Station: " FontSize="11" FontWeight="SemiBold"
                                               Foreground="#888888" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <Ellipse Width="7" Height="7" Fill="#28A745"
                                             VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                            From="1" To="0.2" Duration="0:0:0.9" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <TextBlock x:Name="ConsoleStationName" Text="PAULIS"
                                               FontSize="12" FontWeight="Black" Foreground="#3458e1"
                                               FontFamily="Segoe UI" VerticalAlignment="Center"
                                               TextOptions.TextFormattingMode="Ideal"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- ── CENTER: Time | Players ── -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">

                            <!-- Clock block — fixed width prevents layout jumps when digits change -->
                            <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                <Border Width="168" HorizontalAlignment="Center">
                                    <TextBlock x:Name="ConsoleClockText" Text="00:00:00"
                                               FontSize="30" FontWeight="SemiBold"
                                               Foreground="#111111" FontFamily="Bahnschrift"
                                               HorizontalAlignment="Center"
                                               TextOptions.TextFormattingMode="Ideal"
                                               TextOptions.TextRenderingMode="ClearType"
                                               RenderOptions.ClearTypeHint="Enabled"
                                               SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                                </Border>
                                <TextBlock x:Name="ConsoleDateText" Text="01.06.2026"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#999999" FontFamily="Bahnschrift SemiLight"
                                           HorizontalAlignment="Center"
                                           TextOptions.TextFormattingMode="Ideal"
                                           TextOptions.TextRenderingMode="ClearType"/>
                            </StackPanel>

                            <Border Width="1.5" Height="40" Background="#E8E8E8" Margin="28,0,28,0"/>

                            <!-- Players in PC|MP -->
                            <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                                    <TextBlock Text="Players in " FontSize="9" FontWeight="Black"
                                               Foreground="#AAAAAA" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="PC|MP:" FontSize="9" FontWeight="Black"
                                               Foreground="#3458e1" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="ConsoleTotalPlayers" Text="12"
                                           FontSize="26" FontWeight="Black" Foreground="#3458e1"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                                           TextOptions.TextFormattingMode="Ideal"/>
                            </StackPanel>

                            <Border Width="1.5" Height="40" Background="#E8E8E8" Margin="20,0,20,0"/>

                            <!-- Zone players -->
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                                    <TextBlock Text="At " FontSize="9" FontWeight="Black"
                                               Foreground="#AAAAAA" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ConsoleZoneStatLabel" Text="Paulis:"
                                               FontSize="9" FontWeight="Black"
                                               Foreground="#3458e1" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="ConsoleZonePlayers" Text="2"
                                           FontSize="26" FontWeight="Black" Foreground="#3458e1"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                                           TextOptions.TextFormattingMode="Ideal"/>
                            </StackPanel>

                            <Border Width="1.5" Height="40" Background="#E8E8E8" Margin="20,0,20,0"/>

                            <!-- Dispatched by -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="DISPATCHED BY" FontSize="9" FontWeight="Black"
                                           Foreground="#AAAAAA" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <TextBlock x:Name="ConsoleSubtitleText" Text="Polikarp.K."
                                           FontSize="15" FontWeight="Black" Foreground="#111111"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                                           TextOptions.TextFormattingMode="Ideal"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- ── RIGHT: Disconnect ── -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="0,0,150,0">
                            <Button Padding="16,8" Click="OnDisconnect_Click"
                                    Cursor="Hand"
                                    UseLayoutRounding="True" SnapsToDevicePixels="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" BorderBrush="#3458e1" BorderThickness="1.5"
                                                CornerRadius="0" Padding="{TemplateBinding Padding}"
                                                Background="#F0F4FF"
                                                UseLayoutRounding="True" SnapsToDevicePixels="True">
                                            <TextBlock x:Name="BtnTxt" Text="Disconnect" FontSize="13"
                                                       FontWeight="Black" Foreground="#3458e1"
                                                       FontFamily="Segoe UI"
                                                       UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3458e1"/>
                                                <Setter TargetName="BtnTxt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- ── Bottom separator — crisp black line ── -->
                    <Grid Grid.Row="1">
                        <Border Height="2" Background="#111111"/>
                        <Border Height="1" Background="#3458e1" Opacity="0.18" Margin="0,2,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Map + widget layout ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="270"/>
                </Grid.RowDefinitions>

                <!-- Map (прижата к левому краю) -->
                <Grid Grid.Column="0" Grid.Row="0">
                    <local:MapView x:Name="MapControl"/>
                </Grid>

                <!-- Правая панель -->
                <Border x:Name="RightPanel" Grid.Column="1" Grid.Row="0"
                        Background="#080c1e"
                        BorderBrush="#1e2440" BorderThickness="1,0,0,0"/>

                <!-- Нижняя панель: [Поезда] | [Чат] | [Резерв белый] -->
                <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                      Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TrainsContainer" Grid.Column="0"
                            Background="White"
                            BorderBrush="#E8E8E8" BorderThickness="0,1,1,0"/>
                    <Border x:Name="ChatContainer" Grid.Column="1"
                            Background="White"
                            BorderBrush="#E8E8E8" BorderThickness="0,1,1,0"/>
                    <Border x:Name="BottomRightPanel" Grid.Column="2"
                            Background="White"
                            BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"/>
                </Grid>

                <!-- Высота нижней панели задана в RowDefinition -->
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  BRAND TRANSITION OVERLAY                               -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="TransitionOverlay" Panel.ZIndex="9999" Visibility="Collapsed"
              Background="White" Opacity="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        x:Name="BrandContainer" RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <ScaleTransform x:Name="BrandScale" ScaleX="0" ScaleY="0"/>
                </StackPanel.RenderTransform>
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="PC" FontSize="84" FontWeight="Black"
                               Foreground="#3458e1" TextOptions.TextFormattingMode="Ideal"/>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="|" FontSize="84" FontWeight="Black"
                               Foreground="#3458e1" TextOptions.TextFormattingMode="Ideal"/>
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="MP" FontSize="84" FontWeight="Black"
                               Foreground="#3458e1" TextOptions.TextFormattingMode="Ideal"/>
                    <Border Grid.Column="1" Grid.Row="1" Height="4" Background="#3458e1"
                            HorizontalAlignment="Stretch" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  CONNECTING OVERLAY                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="ConnectingOverlay" Visibility="Collapsed" Panel.ZIndex="20" Background="#CC0f1117">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="ConnectingText" Text="Connecting…"
                           FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"
                           TextOptions.TextFormattingMode="Ideal"/>
                <Border Height="4" Width="300" Background="#2a2d3e" CornerRadius="2" Margin="0,16,0,0">
                    <Border x:Name="ConnectProgress" HorizontalAlignment="Left"
                            Background="#3458e1" Height="4" Width="0" CornerRadius="2"/>
                </Border>
                <TextBlock Text="Please wait" FontSize="13" Foreground="#555"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>




