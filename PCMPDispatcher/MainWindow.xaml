<Window x:Class="PCMPDispatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PCMPDispatcher"
        Title="PC|MP Dispatcher"
        WindowState="Maximized"
        WindowStyle="None"
        Background="White"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        UseLayoutRounding="True"
        TextOptions.TextRenderingMode="ClearType">


    <Grid x:Name="RootGrid">

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  WINDOW CAPTION CONTROLS (global, top-right)            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- Soft gray outline — only shown in windowed (Normal) state -->
        <Border x:Name="WindowBorder" Panel.ZIndex="100000" IsHitTestVisible="False"
                BorderBrush="#B5B5B5" BorderThickness="0"/>

        <Grid Panel.ZIndex="99999" VerticalAlignment="Top" Height="34">
            <!-- Drag strip: move the window by dragging the very top edge -->
            <Border x:Name="DragStrip" Background="Transparent"
                    HorizontalAlignment="Stretch" Margin="0,0,150,0"
                    MouseLeftButtonDown="OnTitleBarDrag"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel.Resources>
                    <Style x:Key="CaptionBtn" TargetType="Button">
                        <Setter Property="Width" Value="46"/>
                        <Setter Property="Height" Value="34"/>
                        <Setter Property="Foreground" Value="#444"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#E5E5E5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Resources>

                <Button x:Name="MinBtn" Style="{StaticResource CaptionBtn}" Content="&#xE921;"
                        ToolTip="Свернуть" Click="OnMinimize_Click"/>
                <Button x:Name="MaxBtn" Style="{StaticResource CaptionBtn}" Content="&#xE922;"
                        ToolTip="Свернуть в окно" Click="OnMaxRestore_Click"/>
                <Button x:Name="CloseBtn2" Content="&#xE8BB;"
                        ToolTip="Закрыть" Click="OnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CloseBtn}"/>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 1 — SPLASH                                        -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="SplashPage" Background="White" Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid HorizontalAlignment="Center">
                    <TextBlock x:Name="SplashWelcome"
                               Text="Welcome"
                               FontSize="64" FontWeight="Black"
                               Foreground="#000000"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               TextOptions.TextFormattingMode="Ideal"
                               RenderOptions.ClearTypeHint="Enabled">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="WelcomeScale" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="SplashTagline"
                               Text="for You - for Us. For everyone."
                               FontSize="26" FontWeight="Normal"
                               Foreground="#000000"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               RenderTransformOrigin="0.5,0.5"
                               TextOptions.TextFormattingMode="Ideal"
                               RenderOptions.ClearTypeHint="Enabled">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="TaglineScale" ScaleY="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
                <Border x:Name="SplashProgressTrack" Height="3" Width="300" Margin="0,40,0,0"
                        Background="#EEEEEE" CornerRadius="2">
                    <Border x:Name="SplashProgress" HorizontalAlignment="Left"
                            Background="#3458e1" Height="3" Width="0" CornerRadius="2"/>
                </Border>
            </StackPanel>
            <TextBlock Text="PC|MP Dispatch System" FontSize="11" Foreground="#CCCCCC"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,16"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 1.5 — ROLE PICKER                                 -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="RolePicker" Visibility="Collapsed" Panel.ZIndex="8"
              MouseMove="OnRolePickerMouseMove">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#070E2E" Offset="0"/>
                    <GradientStop Color="#0C1640" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.Resources>
                <Style x:Key="RolePlate" TargetType="Border">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="BorderBrush" Value="White"/>
                    <Setter Property="BorderThickness" Value="3"/>
                    <Setter Property="CornerRadius" Value="4"/>
                    <Setter Property="ClipToBounds" Value="True"/>
                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <SkewTransform AngleX="-12"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="#3458e1"/>
                            <Setter Property="BorderThickness" Value="5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Resources>

            <!-- Soft white glow that trails the cursor, behind everything -->
            <Canvas IsHitTestVisible="False" ClipToBounds="True">
                <Ellipse x:Name="CursorGlow" Width="760" Height="760">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#26FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="0.45"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="GlowT" X="-1000" Y="-1000"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <!-- Faint PC|MP watermarks — scattered & tilted; opacity is driven
                 entirely from a single per-frame loop in code (OnGlowFrame). -->
            <Grid IsHitTestVisible="False" ClipToBounds="True">
                <Grid.Resources>
                    <Style x:Key="Wmark" TargetType="TextBlock">
                        <Setter Property="Text" Value="PC|MP"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontWeight" Value="Black"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Opacity" Value="0.06"/>
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                    </Style>
                </Grid.Resources>

                <TextBlock x:Name="Wm1" Style="{StaticResource Wmark}" FontSize="190"
                           HorizontalAlignment="Left" VerticalAlignment="Top" Margin="60,30,0,0">
                    <TextBlock.RenderTransform><RotateTransform Angle="-16"/></TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="Wm2" Style="{StaticResource Wmark}" FontSize="110"
                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,120,90,0">
                    <TextBlock.RenderTransform><RotateTransform Angle="11"/></TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="Wm3" Style="{StaticResource Wmark}" FontSize="150"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,120,80">
                    <TextBlock.RenderTransform><RotateTransform Angle="-9"/></TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="Wm4" Style="{StaticResource Wmark}" FontSize="90"
                           HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="120,0,0,70">
                    <TextBlock.RenderTransform><RotateTransform Angle="14"/></TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="Wm5" Style="{StaticResource Wmark}" FontSize="70"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0">
                    <TextBlock.RenderTransform><RotateTransform Angle="-22"/></TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="Wm6" Style="{StaticResource Wmark}" FontSize="80"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
                    <TextBlock.RenderTransform><RotateTransform Angle="18"/></TextBlock.RenderTransform>
                </TextBlock>
            </Grid>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="CHOOSE WHO YOU'LL BE HERE"
                           FontFamily="Segoe UI" FontWeight="Black" FontSize="40"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"
                           TextOptions.TextFormattingMode="Ideal"/>
                <TextBlock FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="18"
                           HorizontalAlignment="Center" Margin="0,0,0,40"
                           TextOptions.TextFormattingMode="Ideal">
                    <Run Text="Choose your role on " Foreground="#9aa3b5"/><Run Text="PC|MP" FontWeight="Black" Foreground="#3458e1"/><Run Text="!" Foreground="#9aa3b5"/>
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- DISPATCHER — left of center -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource RolePlate}"
                            Width="470" Height="300" Tag="Dispatcher"
                            MouseLeftButtonUp="OnRoleSelected">
                        <Grid>
                            <Image Source="Assets/Dispatcher.jpg" Stretch="UniformToFill"/>
                            <Border Background="#A6000000"/>
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,28"
                                        RenderTransformOrigin="0.5,0.5">
                                <StackPanel.RenderTransform>
                                    <SkewTransform AngleX="12"/>
                                </StackPanel.RenderTransform>
                                <TextBlock Text="DISPATCHER" FontFamily="Segoe UI" FontWeight="Black"
                                           FontSize="38" Foreground="White" HorizontalAlignment="Center"
                                           TextOptions.TextFormattingMode="Ideal"/>
                                <TextBlock Text="Control signals, switches and traffic"
                                           FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14"
                                           Foreground="#cfd6e4" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DRIVER — right of center -->
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource RolePlate}"
                            Width="470" Height="300" Tag="Driver"
                            MouseLeftButtonUp="OnRoleSelected">
                        <Grid>
                            <Image Source="Assets/Drivers.jpg" Stretch="UniformToFill"/>
                            <Border Background="#A6000000"/>
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,28"
                                        RenderTransformOrigin="0.5,0.5">
                                <StackPanel.RenderTransform>
                                    <SkewTransform AngleX="12"/>
                                </StackPanel.RenderTransform>
                                <TextBlock Text="DRIVER" FontFamily="Segoe UI" FontWeight="Black"
                                           FontSize="38" Foreground="White" HorizontalAlignment="Center"
                                           TextOptions.TextFormattingMode="Ideal"/>
                                <TextBlock Text="Drive trains across the route"
                                           FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14"
                                           Foreground="#cfd6e4" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- OBSERVATOR — centered below -->
                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource RolePlate}"
                            Width="560" Height="170" Tag="Observator" HorizontalAlignment="Center"
                            MouseLeftButtonUp="OnRoleSelected">
                        <Grid>
                            <Image Source="Assets/Observator.jpg" Stretch="UniformToFill"/>
                            <Border Background="#A6000000"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5">
                                <StackPanel.RenderTransform>
                                    <SkewTransform AngleX="12"/>
                                </StackPanel.RenderTransform>
                                <TextBlock Text="OBSERVATOR" FontFamily="Segoe UI" FontWeight="Black"
                                           FontSize="34" Foreground="White" HorizontalAlignment="Center"
                                           TextOptions.TextFormattingMode="Ideal"/>
                                <TextBlock Text="Just connect and watch the network live"
                                           FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14"
                                           Foreground="#cfd6e4" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock x:Name="RoleComingSoon" Text="" Visibility="Collapsed"
                           FontFamily="Segoe UI" FontWeight="Bold" FontSize="15"
                           Foreground="#3458e1" HorizontalAlignment="Center" Margin="0,32,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 2 — MAIN (Home)                                   -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="MainPage" Background="White" Visibility="Collapsed" Panel.ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- ── Top bar ── -->
            <Border Grid.Row="0" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Background="White">
                <Grid Margin="28,0,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="Assets/logo.png" Width="160" Height="42"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                            <TextBlock x:Name="TopClockText" Text="00:00:00"
                                       FontSize="22" FontWeight="SemiBold" Foreground="#111111" FontFamily="Bahnschrift" HorizontalAlignment="Center"
                                       TextOptions.TextFormattingMode="Display"
                                       SnapsToDevicePixels="True"/>
                            <TextBlock x:Name="TopDateText" Text="01.06.2026"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#555555" FontFamily="Bahnschrift SemiLight" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Border Width="1" Height="36" Background="#EEEEEE" Margin="0,0,24,0"/>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" Fill="#28A745" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#28A745" Opacity="0.8" BlurRadius="6" ShadowDepth="0"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="RO.sv-1" FontSize="14" FontWeight="Bold"
                                           Foreground="#000000" Margin="7,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Active" FontSize="11" Foreground="#28A745" Margin="16,0,0,0"/>
                        </StackPanel>
                        <Border Width="1" Height="36" Background="#EEEEEE" Margin="0,0,24,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Active players" FontSize="11" Foreground="#888888"/>
                            <TextBlock Text="13" FontSize="20" FontWeight="Black" Foreground="#3458e1"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,150,0">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock Text="Welcome," FontSize="12" Foreground="#888888" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="HomeUserName" Text="Polikarp"
                                       FontSize="16" FontWeight="Bold" Foreground="#000000" HorizontalAlignment="Right"/>
                        </StackPanel>
                        <Border Width="44" Height="44" CornerRadius="6" Background="#E8EEFF" VerticalAlignment="Center">
                            <TextBlock Text="P" FontSize="20" FontWeight="Bold" Foreground="#3458e1"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main 2-column (50/50) ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical separator -->
                <Border Grid.Column="0" Width="1" Background="#F0F0F0"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"/>

                <!-- ═══ LEFT PANEL ═══ -->
                <Grid Grid.Column="0" Margin="28,24,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Ready to DISPATCH?"
                                   FontSize="26" FontWeight="Black" Foreground="#000000"
                                   TextOptions.TextFormattingMode="Ideal"/>
                        <TextBlock Text="Select a route to begin dispatching"
                                   FontSize="15" Foreground="#666666" Margin="0,5,0,0"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Scrollable middle: card + description -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- "Available Routes" + divider matching text width -->
                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="Available Routes" FontSize="14" FontWeight="Bold"
                                           Foreground="#222222" FontFamily="Segoe UI"/>
                                <Border Height="1.5" Background="#BBBBBB" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Number badge "1" above card — crisp, snapped to pixels -->
                            <Grid HorizontalAlignment="Left" Margin="4,0,0,6"
                                  Width="26" Height="26"
                                  SnapsToDevicePixels="True" UseLayoutRounding="True">
                                <Ellipse Width="26" Height="26" Fill="White"
                                         Stroke="#111111" StrokeThickness="1.5"
                                         SnapsToDevicePixels="True"/>
                                <TextBlock Text="1" FontSize="13" FontWeight="Black"
                                           Foreground="#111111"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextOptions.TextFormattingMode="Display"
                                           SnapsToDevicePixels="True"/>
                            </Grid>

                            <!-- ── Route Card outer wrapper (rectangular selection border) ── -->
                            <Border x:Name="RouteCardBorder"
                                    BorderThickness="0" BorderBrush="Transparent"
                                    CornerRadius="0" Cursor="Hand"
                                    MouseLeftButtonUp="OnRouteCardToggle">
                                <!-- Inner card with rounded photo corners -->
                                <Border Height="165" CornerRadius="10" ClipToBounds="True">
                                    <Grid>
                                        <Image Source="Assets/PMG3.png" Stretch="UniformToFill"/>
                                        <Border Background="#D80a0f1e"/>
                                        <Grid Margin="14,12,14,10">

                                            <!-- TOP: Publisher badge + M200 badge inline + reverse SVG -->
                                            <Grid VerticalAlignment="Top">
                                                <!-- Left: Publisher + M200 badges in a row -->
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                    <Border Background="#3458e1" CornerRadius="5"
                                                            Padding="10,4" Margin="0,0,6,0">
                                                        <TextBlock Text="Publisher: Poli&amp;Co Official"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <Border Background="White" CornerRadius="5"
                                                            Padding="8,4">
                                                        <TextBlock Text="M200"
                                                                   FontSize="11" FontWeight="Black"
                                                                   Foreground="#3458e1"/>
                                                    </Border>
                                                    <!-- Server indicator -->
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0">
                                                        <Ellipse Width="8" Height="8" Fill="#28A745"
                                                                 VerticalAlignment="Center">
                                                            <Ellipse.Triggers>
                                                                <EventTrigger RoutedEvent="Loaded">
                                                                    <BeginStoryboard>
                                                                        <Storyboard RepeatBehavior="Forever">
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                From="1" To="0.15"
                                                                                Duration="0:0:0.9"
                                                                                AutoReverse="True"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Ellipse.Triggers>
                                                        </Ellipse>
                                                        <TextBlock Text=" RO.sv-1"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#28A745"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Right: left icon — same level as badges -->
                                                <Image Source="Assets/left icon.png"
                                                       Width="52" Height="52"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>

                                            <!-- MIDDLE: Route name -->
                                            <TextBlock Text="M200  Arad — Radna"
                                                       FontSize="22" FontWeight="Black"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       TextOptions.TextFormattingMode="Ideal"/>

                                            <!-- BOTTOM: Station timeline + logo watermark -->
                                            <Grid VerticalAlignment="Bottom">
                                                <!-- Station timeline -->
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="15"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- Names: all white bold, slightly larger -->
                                                    <UniformGrid Grid.Row="0" Rows="1">
                                                        <TextBlock Text="Arad" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Glogovat" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Ghioroc" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Paulis hc." FontSize="10" Foreground="#AABBCC" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Paulis" FontSize="10" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Radna" FontSize="10" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    </UniformGrid>
                                                    <!-- Circles + line: chaser animation -->
                                                    <Grid Grid.Row="1">
                                                        <Border Height="1.5" Background="White" Opacity="0.35"
                                                                VerticalAlignment="Center" Margin="6,0,6,0"/>
                                                        <UniformGrid Rows="1">
                                                            <Ellipse x:Name="Dot1" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="Dot1Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse x:Name="Dot2" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="Dot2Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse x:Name="Dot3" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="Dot3Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse x:Name="Dot4" Width="7" Height="7" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="Dot4Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse x:Name="Dot5" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="Dot5Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                            <Ellipse x:Name="Dot6" Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse.Fill><SolidColorBrush x:Name="Dot6Brush" Color="#3458e1"/></Ellipse.Fill>
                                                            </Ellipse>
                                                        </UniformGrid>
                                                    </Grid>
                                                </Grid>
                                            </Grid>

                                        </Grid>

                                        <!-- Logo watermark bottom-right -->
                                        <Image Source="Assets/logo.png"
                                               Width="80" Opacity="0.18"
