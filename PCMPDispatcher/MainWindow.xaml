<Window x:Class="PCMPDispatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PCMPDispatcher"
        Title="PC|MP Dispatcher"
        WindowState="Maximized"
        WindowStyle="None"
        Background="White"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        UseLayoutRounding="True"
        TextOptions.TextRenderingMode="ClearType">


    <Grid x:Name="RootGrid">

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  WINDOW CAPTION CONTROLS (global, top-right)            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- Soft gray outline — only shown in windowed (Normal) state -->
        <Border x:Name="WindowBorder" Panel.ZIndex="100000" IsHitTestVisible="False"
                BorderBrush="#B5B5B5" BorderThickness="0"/>

        <Grid Panel.ZIndex="99999" VerticalAlignment="Top" Height="34">
            <!-- Drag strip: move the window by dragging the very top edge -->
            <Border x:Name="DragStrip" Background="Transparent"
                    HorizontalAlignment="Stretch" Margin="0,0,150,0"
                    MouseLeftButtonDown="OnTitleBarDrag"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel.Resources>
                    <Style x:Key="CaptionBtn" TargetType="Button">
                        <Setter Property="Width" Value="46"/>
                        <Setter Property="Height" Value="34"/>
                        <Setter Property="Foreground" Value="#444"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#E5E5E5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Resources>

                <Button x:Name="MinBtn" Style="{StaticResource CaptionBtn}" Content="&#xE921;"
                        ToolTip="Свернуть" Click="OnMinimize_Click"/>
                <Button x:Name="MaxBtn" Style="{StaticResource CaptionBtn}" Content="&#xE922;"
                        ToolTip="Свернуть в окно" Click="OnMaxRestore_Click"/>
                <Button x:Name="CloseBtn2" Content="&#xE8BB;"
                        ToolTip="Закрыть" Click="OnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CloseBtn}"/>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 1 — SPLASH                                        -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:SplashView x:Name="SplashView" Panel.ZIndex="10"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 1.5 — ROLE PICKER                                 -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:RolePickerView x:Name="RolePickerView" Visibility="Collapsed" Panel.ZIndex="8"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 2 — MAIN (Home)                                   -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:DispatcherHomeView x:Name="DispatcherHomeView" Visibility="Collapsed" Panel.ZIndex="5"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 2-D — DRIVER (Home)  — same chrome, empty body    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:DriverHomeView x:Name="DriverHomeView" Visibility="Collapsed" Panel.ZIndex="5"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 2-D2 — DRIVER SET-UP (Step 1: schedule)          -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:DrvSetupView x:Name="DrvSetupView" Visibility="Collapsed" Panel.ZIndex="5"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 2-D3 — DRIVER FINAL (run sheet)                   -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:DrvFinalView x:Name="DrvFinalView" Visibility="Collapsed" Panel.ZIndex="5"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 3 — DISPATCHERS CONFIG                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:StationSelectView x:Name="StationSelectView" Visibility="Collapsed" Panel.ZIndex="5"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  PAGE 4 — DISPATCHER CONSOLE                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <local:ConsoleView x:Name="ConsoleView" Visibility="Collapsed" Panel.ZIndex="5"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  BRAND TRANSITION OVERLAY                               -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="TransitionOverlay" Panel.ZIndex="9999" Visibility="Collapsed"
              Background="White" Opacity="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        x:Name="BrandContainer" RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <ScaleTransform x:Name="BrandScale" ScaleX="0" ScaleY="0"/>
                </StackPanel.RenderTransform>
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="PC" FontSize="84" FontWeight="Black"
                               Foreground="#3458e1" TextOptions.TextFormattingMode="Ideal"/>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="|" FontSize="84" FontWeight="Black"
                               Foreground="#3458e1" TextOptions.TextFormattingMode="Ideal"/>
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="MP" FontSize="84" FontWeight="Black"
                               Foreground="#3458e1" TextOptions.TextFormattingMode="Ideal"/>
                    <Border Grid.Column="1" Grid.Row="1" Height="4" Background="#3458e1"
                            HorizontalAlignment="Stretch" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  CONNECTING OVERLAY                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="ConnectingOverlay" Visibility="Collapsed" Panel.ZIndex="20" Background="#CC0f1117">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="ConnectingText" Text="Connecting…"
                           FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"
                           TextOptions.TextFormattingMode="Ideal"/>
                <Border Height="4" Width="300" Background="#2a2d3e" CornerRadius="2" Margin="0,16,0,0">
                    <Border x:Name="ConnectProgress" HorizontalAlignment="Left"
                            Background="#3458e1" Height="4" Width="0" CornerRadius="2"/>
                </Border>
                <TextBlock Text="Please wait" FontSize="13" Foreground="#555"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>




